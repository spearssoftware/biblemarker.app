---
import Landing from '../layouts/Landing.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Landing title="Share BibleMarker" description="Share BibleMarker with friends and family. Scan a QR code to visit the website or download from the App Store.">
  <Nav />

  <section class="share">
    <div class="container">
      <h1>Share BibleMarker</h1>
      <p class="subtitle">Scan a QR code to share with friends and family</p>
      <div class="qr-grid">
        <div class="qr-card">
          <a href="https://biblemarker.app" class="qr-wrapper">
            <img src="/images/qr-website.svg" alt="Scan to visit biblemarker.app" width="240" height="240" />
          </a>
          <p class="qr-label">Website</p>
          <p class="qr-url">biblemarker.app</p>
        </div>
        <div class="qr-card">
          <a href="https://apps.apple.com/us/app/biblemarker/id6759001361" target="_blank" rel="noopener noreferrer" class="qr-wrapper">
            <img src="/images/qr-appstore.svg" alt="Scan to download BibleMarker on the App Store" width="240" height="240" />
          </a>
          <p class="qr-label">iOS App Store</p>
          <p class="qr-url">Download for iPhone &amp; iPad</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Landing>

<style>
  .share {
    padding: 5rem 0 4rem;
    text-align: center;
  }

  .share h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }

  .qr-grid {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .qr-card {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .qr-wrapper {
    display: inline-block;
    width: 240px;
    height: 240px;
    padding: 1.5rem;
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    margin-bottom: 1rem;
  }

  .qr-wrapper img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .qr-label {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .qr-url {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>
